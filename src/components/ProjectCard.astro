---
import TechBadge from './TechBadge.astro';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import type { Project } from '../i18n/projects';

interface Props {
  project: Project;
  index: number;
  lang: Lang;
}

const { project, index, lang } = Astro.props;
const isReversed = index % 2 !== 0;

const glowColors: Record<string, { border: string; shadow: string }> = {
  'rechnungswerk': { border: 'hover:border-emerald-500/30', shadow: 'hover:shadow-[0_0_30px_-5px_rgba(16,185,129,0.15)]' },
  'mathemaxxing': { border: 'hover:border-amber-500/30', shadow: 'hover:shadow-[0_0_30px_-5px_rgba(245,158,11,0.15)]' },
  'eloquent': { border: 'hover:border-violet-500/30', shadow: 'hover:shadow-[0_0_30px_-5px_rgba(139,92,246,0.15)]' },
  'job-sniper': { border: 'hover:border-rose-500/30', shadow: 'hover:shadow-[0_0_30px_-5px_rgba(244,63,94,0.15)]' },
  'claude-orchestrator': { border: 'hover:border-cyan-500/30', shadow: 'hover:shadow-[0_0_30px_-5px_rgba(34,211,238,0.15)]' },
};

const glow = glowColors[project.id] || { border: 'hover:border-accent/30', shadow: 'hover:shadow-glow' };
---

<div class={`grid md:grid-cols-2 gap-8 md:gap-16 items-center ${isReversed ? 'md:[direction:rtl] md:*:[direction:ltr]' : ''}`} data-reveal>
  <!-- Screenshot with browser mockup -->
  <div class="relative group">
    <div class={`bg-surface border border-border rounded-xl overflow-hidden transition-all duration-300 ${glow.border} ${glow.shadow}`}>
      <!-- Browser bar -->
      <div class="flex items-center gap-2 px-4 py-3 bg-[#0a0a0f] border-b border-border">
        <div class="flex gap-1.5">
          <div class="w-2.5 h-2.5 rounded-full bg-[#3a3a4a]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#3a3a4a]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#3a3a4a]"></div>
        </div>
        <div class="flex-1 mx-4">
          <div class="bg-[#1a1a25] rounded-md px-3 py-1 text-xs text-muted font-mono truncate">
            {project.github.replace('https://', '')}
          </div>
        </div>
      </div>
      <!-- Screenshot -->
      <div class="bg-[#0a0a0f] overflow-hidden relative">
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-br from-accent/5 via-accent/10 to-accent/5">
          <span class="text-4xl">{
            project.id === 'rechnungswerk' ? '🧾' :
            project.id === 'mathemaxxing' ? '🧮' :
            project.id === 'eloquent' ? '💬' :
            project.id === 'job-sniper' ? '🎯' :
            project.id === 'claude-orchestrator' ? '🤖' : '📦'
          }</span>
          <span class="text-sm font-medium text-muted">{project.title}</span>
        </div>
        <img
          src={project.screenshot}
          alt={project.title}
          class="w-full h-auto block relative z-10"
          loading="lazy"
          onerror="this.style.display='none'"
        />
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="space-y-6">
    <div>
      <h3 class="font-serif text-3xl md:text-4xl font-bold tracking-tighter mb-3 text-ink">
        {project.title}
      </h3>
      <p class="text-muted text-base leading-relaxed">
        {project.description}
      </p>
    </div>

    <!-- Features -->
    <div>
      <p class="text-xs font-mono uppercase tracking-wider text-muted mb-3">{t(lang, 'projects.features')}</p>
      <ul class="space-y-2">
        {project.features.map(feature => (
          <li class="flex items-start gap-2 text-sm text-ink/80">
            <span class="text-accent mt-0.5 flex-shrink-0">&#10003;</span>
            {feature}
          </li>
        ))}
      </ul>
    </div>

    <!-- Tech stack -->
    <div class="flex flex-wrap gap-2">
      {project.tech.map(tech => (
        <TechBadge name={tech} />
      ))}
    </div>

    <!-- GitHub link -->
    <a
      href={project.github}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm font-medium text-ink hover:text-accent transition-colors group/link"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="opacity-70 group-hover/link:opacity-100">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      {t(lang, 'projects.viewCode')}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover/link:translate-x-0.5">
        <path d="M7 17L17 7M17 7H7M17 7v10"/>
      </svg>
    </a>
  </div>
</div>
