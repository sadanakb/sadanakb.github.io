---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const milestones = [
  {
    year: '2019',
    titleKey: 'timeline.2019.title',
    textKey: 'timeline.2019.text',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"/></svg>`,
  },
  {
    year: '2024',
    titleKey: 'timeline.2024.title',
    textKey: 'timeline.2024.text',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.745 3.745 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>`,
  },
  {
    year: '2024–25',
    titleKey: 'timeline.2025projects.title',
    textKey: 'timeline.2025projects.text',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"/></svg>`,
  },
  {
    year: '10/2025',
    titleKey: 'timeline.2025uni.title',
    textKey: 'timeline.2025uni.text',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21"/></svg>`,
  },
];
---

<section id="timeline" class="py-32 md:py-40 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-serif text-4xl md:text-5xl font-bold tracking-tighter text-ink mb-20 text-center gsap-reveal">
      {t(lang, 'timeline.title')}
    </h2>

    <div class="relative" id="timeline-container">
      <!-- Vertical line (draws via ScrollTrigger) -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px md:-translate-x-px">
        <div class="timeline-line w-full h-full" id="timeline-line"></div>
        <!-- Background track -->
        <div class="absolute inset-0 w-full h-full bg-border/30"></div>
      </div>

      <!-- Milestones -->
      <div class="space-y-16 md:space-y-24">
        {milestones.map((milestone, i) => {
          const isLeft = i % 2 === 0;
          return (
            <div class={`timeline-card relative flex items-start gap-8 ${isLeft ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <!-- Dot on the line -->
              <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-accent border-2 border-[#0a0a0f] z-10 mt-6 timeline-dot"></div>

              <!-- Spacer for line position on mobile -->
              <div class="w-4 shrink-0 md:hidden"></div>

              <!-- Card -->
              <div class={`flex-1 ml-6 md:ml-0 ${isLeft ? 'md:pr-16 md:text-right' : 'md:pl-16 md:text-left'}`}>
                <div class="bg-surface border border-border rounded-2xl p-6 hover:border-accent/20 transition-all duration-300 group relative overflow-hidden">
                  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                  <div class={`flex items-center gap-3 mb-3 ${isLeft ? 'md:justify-end' : ''}`}>
                    <span class="text-accent" set:html={milestone.icon} />
                    <span class="font-mono text-xs tracking-wider text-accent uppercase">{milestone.year}</span>
                  </div>

                  <h3 class="font-serif text-xl font-bold text-ink mb-2">
                    {t(lang, milestone.titleKey)}
                  </h3>
                  <p class="text-muted text-sm leading-relaxed">
                    {t(lang, milestone.textKey)}
                  </p>
                </div>
              </div>

              <!-- Empty space for opposite side on desktop -->
              <div class="hidden md:block flex-1"></div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    // Draw the timeline line
    gsap.to('#timeline-line', {
      scaleY: 1,
      ease: 'none',
      scrollTrigger: {
        trigger: '#timeline-container',
        start: 'top 80%',
        end: 'bottom 60%',
        scrub: true,
      },
    });

    // Animate title
    gsap.from('.gsap-reveal', {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '.gsap-reveal',
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
    });

    // Animate each card and dot
    const cards = document.querySelectorAll('.timeline-card');
    cards.forEach((card, i) => {
      const isLeft = i % 2 === 0;

      gsap.from(card.querySelector('.bg-surface'), {
        x: isLeft ? -30 : 30,
        opacity: 0,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 80%',
          toggleActions: 'play none none none',
        },
      });

      gsap.from(card.querySelector('.timeline-dot'), {
        scale: 0,
        duration: 0.4,
        ease: 'back.out(2)',
        scrollTrigger: {
          trigger: card,
          start: 'top 80%',
          toggleActions: 'play none none none',
        },
      });
    });
  } else {
    // Ensure everything is visible
    const line = document.getElementById('timeline-line');
    if (line) line.style.transform = 'scaleY(1)';
    document.querySelectorAll('.gsap-reveal').forEach(el => {
      (el as HTMLElement).style.opacity = '1';
    });
  }
</script>
