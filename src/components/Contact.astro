---
import MagneticButton from './MagneticButton.astro';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="contact" class="py-40 md:py-52 px-6 relative overflow-hidden">
  <!-- Pulsing gradient orb background -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-accent/[0.06] rounded-full blur-[120px] pointer-events-none contact-orb"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-[#a78bfa]/[0.04] rounded-full blur-[80px] pointer-events-none contact-orb-inner"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10 contact-content">
    <h2 class="font-serif text-5xl md:text-7xl font-bold tracking-tighter mb-6 gradient-text contact-title">
      {t(lang, 'contact.title')}
    </h2>
    <p class="text-muted text-lg md:text-xl mb-12 contact-subtitle">
      {t(lang, 'contact.subtitle')}
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <!-- Email -->
      <MagneticButton strength={0.15}>
        <a
          href="mailto:sadan.akbari8@gmail.com"
          class="inline-flex items-center gap-2 bg-accent text-[#0a0a0f] px-8 py-4 rounded-full text-sm font-semibold hover:shadow-glow transition-shadow duration-300"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          {t(lang, 'contact.email')}
        </a>
      </MagneticButton>

      <!-- LinkedIn -->
      <MagneticButton strength={0.15}>
        <a
          href="https://www.linkedin.com/in/sadan-akbari"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-border px-8 py-4 rounded-full text-sm font-medium text-ink hover:border-accent/50 hover:text-accent transition-all duration-300"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </MagneticButton>

      <!-- GitHub -->
      <MagneticButton strength={0.15}>
        <a
          href="https://github.com/sadanakb"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-border px-8 py-4 rounded-full text-sm font-medium text-ink hover:border-accent/50 hover:text-accent transition-all duration-300"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </MagneticButton>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    // Content reveal
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.contact-content',
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
    });

    tl.from('.contact-title', {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power2.out',
    })
    .from('.contact-subtitle', {
      y: 20,
      opacity: 0,
      duration: 0.6,
      ease: 'power2.out',
    }, '-=0.4')
    .from('.contact-content .magnetic-wrap', {
      y: 20,
      opacity: 0,
      stagger: 0.1,
      duration: 0.5,
      ease: 'power2.out',
    }, '-=0.3');

    // Subtle pulsing orb
    gsap.to('.contact-orb', {
      scale: 1.1,
      opacity: 0.08,
      duration: 3,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1,
    });

    gsap.to('.contact-orb-inner', {
      scale: 0.9,
      opacity: 0.06,
      duration: 2.5,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1,
      delay: 0.5,
    });
  }
</script>
