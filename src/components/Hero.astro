---
import MagneticButton from './MagneticButton.astro';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="hero" class="hero-spotlight relative min-h-screen flex items-center justify-center px-6 overflow-hidden">
  <!-- Parallax gradient mesh blobs -->
  <div class="hero-blob absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-[#22d3ee] rounded-full blur-[150px] opacity-[0.07] pointer-events-none" data-speed="0.3"></div>
  <div class="hero-blob absolute bottom-[-15%] left-[-10%] w-[500px] h-[500px] bg-[#8b5cf6] rounded-full blur-[130px] opacity-[0.06] pointer-events-none" data-speed="0.5"></div>
  <div class="hero-blob absolute top-[40%] left-[60%] w-[300px] h-[300px] bg-[#22d3ee] rounded-full blur-[100px] opacity-[0.04] pointer-events-none" data-speed="0.2"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <!-- Greeting -->
    <p class="hero-greeting text-muted text-lg md:text-xl mb-4 font-sans opacity-0">
      {t(lang, 'hero.greeting')}
    </p>

    <!-- Name with SplitType animation -->
    <h1 class="hero-name font-serif text-hero font-bold tracking-tighter leading-[0.95] gradient-text mb-8 overflow-hidden">
      {t(lang, 'hero.name')}
    </h1>

    <!-- Story-driven subtitle -->
    <p class="hero-subtitle text-muted text-lg md:text-xl max-w-2xl mx-auto leading-relaxed mb-12 opacity-0">
      {t(lang, 'hero.subtitle')}
    </p>

    <!-- Magnetic CTA -->
    <div class="hero-cta opacity-0">
      <MagneticButton strength={0.2}>
        <a
          href="#projects"
          class="inline-flex items-center gap-2 bg-accent text-[#0a0a0f] px-8 py-4 rounded-full text-sm font-semibold hover:shadow-glow transition-shadow duration-300"
          data-lenis-anchor
        >
          {t(lang, 'hero.cta')}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5">
            <path d="M8 3v10M3 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </MagneticButton>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0">
    <div class="flex flex-col items-center gap-2">
      <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-muted/60">{t(lang, 'hero.scroll')}</span>
      <div class="w-px h-8 bg-gradient-to-b from-accent/40 to-transparent animate-bounce-subtle"></div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import SplitType from 'split-type';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    // Show everything immediately
    document.querySelectorAll('.hero-greeting, .hero-subtitle, .hero-cta, .hero-scroll').forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
    });
  } else {
    // Split the name into characters
    const nameEl = document.querySelector('.hero-name');
    if (nameEl) {
      const split = new SplitType(nameEl as HTMLElement, { types: 'chars' });

      // Set initial state for chars
      if (split.chars) {
        gsap.set(split.chars, { y: 100, opacity: 0 });
      }

      // Master timeline for load sequence
      const tl = gsap.timeline({ delay: 0.3 });

      // 1. Greeting fade in
      tl.to('.hero-greeting', {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: 'power2.out',
      });

      // 2. Name letters animate in
      if (split.chars) {
        tl.to(split.chars, {
          y: 0,
          opacity: 1,
          stagger: 0.03,
          duration: 0.8,
          ease: 'power3.out',
        }, '-=0.2');
      }

      // 3. Subtitle fade up
      tl.to('.hero-subtitle', {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power2.out',
      }, '-=0.3');

      // 4. CTA scale in
      tl.fromTo('.hero-cta', {
        opacity: 0,
        scale: 0.9,
      }, {
        opacity: 1,
        scale: 1,
        duration: 0.5,
        ease: 'back.out(1.7)',
      }, '-=0.2');

      // 5. Scroll indicator
      tl.to('.hero-scroll', {
        opacity: 1,
        duration: 0.5,
        ease: 'power2.out',
      }, '-=0.1');
    }

    // Parallax blobs on scroll
    document.querySelectorAll('.hero-blob').forEach((blob) => {
      const speed = parseFloat((blob as HTMLElement).dataset.speed || '0.3');
      gsap.to(blob, {
        y: () => window.innerHeight * speed * -1,
        ease: 'none',
        scrollTrigger: {
          trigger: '#hero',
          start: 'top top',
          end: 'bottom top',
          scrub: 1,
        },
      });
    });
  }

  // Mouse spotlight (works regardless of motion preference)
  const hero = document.getElementById('hero');
  if (hero) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      hero.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      hero.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
      hero.classList.add('active');
    });
    hero.addEventListener('mouseleave', () => {
      hero.classList.remove('active');
    });
  }
</script>
