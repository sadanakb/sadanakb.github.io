---
import ProjectCard from './ProjectCard.astro';
import { t } from '../i18n/utils';
import { getProjects } from '../i18n/projects';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const projects = getProjects(lang);
---

<section id="projects" class="py-32 md:py-40 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="mb-20" data-reveal>
      <h2 class="font-serif text-4xl md:text-5xl font-bold tracking-tighter mb-4 text-ink">
        {t(lang, 'projects.title')}
      </h2>
      <p class="text-muted text-lg max-w-xl">
        {t(lang, 'projects.subtitle')}
      </p>
    </div>

    <div class="space-y-24 md:space-y-32">
      {projects.map((project, index) => (
        <ProjectCard project={project} index={index} lang={lang} />
      ))}
    </div>
  </div>
</section>
