---
import { t } from '../i18n/utils';
import { getProjects } from '../i18n/projects';
import type { Lang } from '../i18n/ui';
import TechBadge from './TechBadge.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const projects = getProjects(lang);

const glowColors: Record<string, string> = {
  'rechnungswerk': 'from-emerald-500/20',
  'mathemaxxing': 'from-amber-500/20',
  'eloquent': 'from-violet-500/20',
  'job-sniper': 'from-rose-500/20',
  'claude-orchestrator': 'from-cyan-500/20',
};
---

<section id="projects" class="py-32 md:py-40 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-20 projects-header">
      <h2 class="font-serif text-4xl md:text-5xl font-bold tracking-tighter mb-4 text-ink">
        {t(lang, 'projects.title')}
      </h2>
      <p class="text-muted text-lg max-w-xl">
        {t(lang, 'projects.subtitle')}
      </p>
    </div>

    <!-- Vertical alternating layout -->
    <div class="space-y-28 md:space-y-36">
      {projects.map((project, index) => {
        const isEven = index % 2 === 1;
        const emoji = project.id === 'rechnungswerk' ? '\u{1F9FE}' :
                      project.id === 'mathemaxxing' ? '\u{1F9EE}' :
                      project.id === 'eloquent' ? '\u{1F4AC}' :
                      project.id === 'job-sniper' ? '\u{1F3AF}' :
                      project.id === 'claude-orchestrator' ? '\u{1F916}' : '\u{1F4E6}';

        return (
          <div class={`project-row grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14 items-center ${isEven ? 'md:direction-rtl' : ''}`}>
            <!-- Screenshot -->
            <div class={`project-screenshot ${isEven ? 'md:order-2' : 'md:order-1'}`}>
              <div class="bg-surface border border-border rounded-xl overflow-hidden transition-all duration-300 hover:border-accent/20 hover:shadow-glow">
                <div class="flex items-center gap-2 px-4 py-3 bg-[#0a0a0f] border-b border-border">
                  <div class="flex gap-1.5">
                    <div class="w-2.5 h-2.5 rounded-full bg-[#3a3a4a]"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-[#3a3a4a]"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-[#3a3a4a]"></div>
                  </div>
                  <div class="flex-1 mx-4">
                    <div class="bg-[#1a1a25] rounded-md px-3 py-1 text-xs text-muted font-mono truncate">
                      {project.github.replace('https://', '')}
                    </div>
                  </div>
                </div>
                <div class="bg-[#0a0a0f] overflow-hidden relative aspect-[16/10]">
                  <div class={`absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-br ${glowColors[project.id] || 'from-accent/5'} via-transparent to-transparent`}>
                    <span class="text-4xl">{emoji}</span>
                    <span class="text-sm font-medium text-muted">{project.title}</span>
                  </div>
                  <img
                    src={project.screenshot}
                    alt={project.title}
                    class="w-full h-full object-contain relative z-10"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    onerror="this.style.display='none'"
                  />
                </div>
              </div>
            </div>

            <!-- Content -->
            <div class={`project-content space-y-6 ${isEven ? 'md:order-1' : 'md:order-2'}`}>
              <div class="flex items-center gap-3 mb-2">
                <span class="font-mono text-xs text-accent tracking-wider">
                  {String(index + 1).padStart(2, '0')} / {String(projects.length).padStart(2, '0')}
                </span>
              </div>
              <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-bold tracking-tighter text-ink">
                {project.title}
              </h3>
              <p class="text-muted text-base leading-relaxed">
                {project.description}
              </p>

              <div>
                <p class="text-xs font-mono uppercase tracking-wider text-muted mb-3">{t(lang, 'projects.features')}</p>
                <ul class="space-y-2">
                  {project.features.map(feature => (
                    <li class="flex items-start gap-2 text-sm text-ink/80">
                      <span class="text-accent mt-0.5 flex-shrink-0">&#10003;</span>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="flex flex-wrap gap-2">
                {project.tech.map(tech => (
                  <TechBadge name={tech} />
                ))}
              </div>

              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-medium text-ink hover:text-accent transition-colors group/link link-animated"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="opacity-70 group-hover/link:opacity-100">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                {t(lang, 'projects.viewCode')}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover/link:translate-x-0.5">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    // Header reveal
    ScrollTrigger.create({
      trigger: '.projects-header',
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.fromTo('.projects-header',
          { y: 30, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.8, ease: 'power2.out' }
        );
      },
    });

    // Each project row: stagger screenshot and content
    document.querySelectorAll('.project-row').forEach((row) => {
      const screenshot = row.querySelector('.project-screenshot');
      const content = row.querySelector('.project-content');

      if (screenshot) {
        ScrollTrigger.create({
          trigger: row,
          start: 'top 85%',
          once: true,
          onEnter: () => {
            gsap.fromTo(screenshot,
              { y: 40, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.7, ease: 'power2.out' }
            );
          },
        });
      }

      if (content) {
        ScrollTrigger.create({
          trigger: row,
          start: 'top 80%',
          once: true,
          onEnter: () => {
            gsap.fromTo(content,
              { y: 40, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.7, delay: 0.15, ease: 'power2.out' }
            );
          },
        });
      }
    });
  }
</script>
