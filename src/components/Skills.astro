---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const categories = [
  {
    title: t(lang, 'skills.dev'),
    skills: ['JavaScript / TypeScript', 'React', 'Next.js', 'Python', 'FastAPI', 'Tailwind CSS', 'Astro', 'HTML & CSS'],
    accent: 'border-l-cyan-500',
  },
  {
    title: t(lang, 'skills.ai'),
    skills: ['Claude Code', 'Claude API', 'Prompt Engineering'],
    accent: 'border-l-violet-500',
  },
  {
    title: t(lang, 'skills.tools'),
    skills: ['Git & GitHub', 'Bash / Shell', 'Vercel', 'VS Code'],
    accent: 'border-l-emerald-500',
  },
];
---

<section id="skills" class="py-32 md:py-40 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-serif text-4xl md:text-5xl font-bold tracking-tighter mb-16 text-ink" data-reveal>
      {t(lang, 'skills.title')}
    </h2>

    <div class="grid md:grid-cols-3 gap-8" data-reveal-stagger>
      {categories.map(cat => (
        <div class={`bg-surface/50 border border-border rounded-2xl p-6 border-l-2 ${cat.accent}`}>
          <h3 class="text-xs font-mono uppercase tracking-wider text-muted mb-6">{cat.title}</h3>
          <div class="flex flex-wrap gap-2">
            {cat.skills.map(skill => (
              <span class="px-3 py-1.5 text-sm font-mono bg-surface border border-border rounded-full text-ink/80 hover:border-accent/30 hover:text-accent transition-all duration-200">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
